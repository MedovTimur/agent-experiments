type PurchaseReceipt = struct {
  listing_id: u64,
  buyer: actor_id,
  seller: actor_id,
  seller_amount: u128,
  admin_fee: u128,
  paid: u128,
};

type Error = enum {
  Unauthorized,
  ZeroPrice,
  EmptyContentHash,
  ListingMissing,
  ListingClosed,
  Underpaid,
  ArithmeticOverflow,
  WithdrawExceedsBalance,
  TransferFailed,
};

type Listing = struct {
  id: u64,
  seller: actor_id,
  content_hash: [u8, 32],
  price: u128,
  active: bool,
};

constructor {
  Create : (admin: actor_id);
};

service AdminFeeMarket {
  Buy : (listing_id: u64, payment: u128) -> result (PurchaseReceipt, Error);
  CreateListing : (content_hash: [u8, 32], price: u128) -> result (u64, Error);
  WithdrawAdminFee : (amount: u128) -> result (u128, Error);
  WithdrawSellerBalance : (amount: u128) -> result (u128, Error);
  query Admin : () -> actor_id;
  query AdminBalance : () -> u128;
  query GetListing : (listing_id: u64) -> opt Listing;
  query ListingCount : () -> u64;
  query SellerBalance : (seller: actor_id) -> u128;

  events {
    ListingCreated: struct {
      listing_id: u64,
      seller: actor_id,
      price: u128,
    };
    ListingPurchased: struct {
      listing_id: u64,
      buyer: actor_id,
      seller: actor_id,
      seller_amount: u128,
      admin_fee: u128,
    };
    AdminFeeWithdrawn: struct {
      admin: actor_id,
      amount: u128,
    };
    SellerBalanceWithdrawn: struct {
      seller: actor_id,
      amount: u128,
    };
  }
};

